# BNR Licensing API — environment template

NODE_ENV=development
PORT=3000

# Minimum 32 characters recommended for production
JWT_SECRET=replace-with-a-strong-secret

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bnr
POSTGRES_PASSWORD=bnr
POSTGRES_DB=bnr
PG_POOL_MAX=10

# Single origin or * for development
CORS_ORIGIN=*

# Optional — override default seeded passwords from scripts/seed.ts
# SEED_SUPERUSER_PASSWORD=
# SEED_ADMIN_PASSWORD=
# SEED_APPLICANT_PASSWORD=
# SEED_REVIEWER_PASSWORD=
